# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/gjts_karnataka
# For production, use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gjts_karnataka

# JWT Secret (Change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# For Gmail App Password:
# 1. Enable 2-Factor Authentication
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate app password for "Mail"
# 4. Use the 16-character password above

# Application Configuration
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# MongoDB Docker Configuration (for docker-compose)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password123

# AWS Configuration (for deployment)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
